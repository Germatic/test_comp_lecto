PORT=3000

# Optional: when set, the app enables analytics logging in PostgreSQL.
DATABASE_URL=postgresql://user:password@localhost:5432/test_comp_lecto

# Optional: set this to a stable secret so hashed IPs remain consistent across restarts.
ANALYTICS_IP_SALT=replace-with-a-long-random-secret

# Optional: set to true when the PostgreSQL server requires SSL.
DATABASE_SSL=false

# Optional but recommended when analytics is enabled.
# Protects the admin/export endpoints under /api/admin/*
ADMIN_API_TOKEN=replace-with-a-long-random-admin-token
